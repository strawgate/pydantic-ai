#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "pydantic-ai-slim[openai,anthropic,mcp]>=1.95.1",
#   "logfire",
# ]
# ///
"""Pydantic AI harness — a drop-in replacement for the Claude Code CLI in gh-aw.

gh-aw runs the agent engine like the Claude Code CLI:

    <command> --print --no-chrome --allowed-tools '<csv>' --debug-file <path> \\
      --verbose --permission-mode <mode> --output-format stream-json \\
      --mcp-config <mcp-servers.json> --prompt-file <prompt.txt> \\
      [--model <model>] "<rendered prompt>"

With ``engine.command`` set, ``<command>`` is this script. It speaks Claude
Code's argv, recovers the prompt, builds a `pydantic-ai` agent backed by the
gh-aw-injected Anthropic/OpenAI-compatible proxy, exposes Claude-named native
tools plus gh-aw's MCP servers (GitHub + the ``safeoutputs`` write-sink),
enforces gh-aw's ``--allowed-tools`` allow-list, and emits Claude-compatible
``stream-json`` so gh-aw's log parser and token accounting keep working.

Credentials note: under gh-aw the real API key is *excluded* from the agent
container (``awf --exclude-env ANTHROPIC_API_KEY``). The AWF api-proxy injects
it transparently; the harness only ever sends a placeholder token to the
proxy base URL — never a real upstream key.
"""

import argparse
import asyncio
import glob as globlib
import json
import os
import pathlib
import re
import shutil
import subprocess
import sys
import time
import uuid
from collections.abc import Callable, Iterable, Sequence
from dataclasses import dataclass
from typing import Any

import logfire
from anthropic import AsyncAnthropic
from pydantic_ai import Agent, RunContext, Tool
from pydantic_ai.mcp import MCPToolset
from pydantic_ai.messages import ModelResponse, ToolCallPart, ToolReturnPart
from pydantic_ai.models import Model
from pydantic_ai.models.anthropic import AnthropicModel
from pydantic_ai.models.openai import OpenAIChatModel
from pydantic_ai.providers.anthropic import AnthropicProvider
from pydantic_ai.providers.openai import OpenAIProvider
from pydantic_ai.tools import ToolDefinition
from pydantic_ai.toolsets import AbstractToolset

PROXY_PLACEHOLDER = "gh-aw-proxy-injected"

# Claude Code native tools the harness implements. The model is trained on
# these exact names/parameters, so matching them (rather than a custom set +
# a fragile rename map) makes the harness a faithful drop-in.
NATIVE_TOOL_NAMES = ("Bash", "Read", "Write", "Edit", "Grep", "Glob", "LS")
# Tools that mutate the workspace — withheld in `plan` permission mode.
MUTATING_TOOLS = frozenset({"Bash", "Write", "Edit"})


def log(msg: str) -> None:
    """Diagnostics go to stderr; stdout is reserved for stream-json."""
    print(f"[pydantic-ai-harness] {msg}", file=sys.stderr, flush=True)


@dataclass(slots=True)
class Args:
    """The subset of Claude Code's CLI surface the harness acts on."""

    model: str | None = None
    mcp_config: str | None = None
    prompt_file: str | None = None
    prompt_positional: str | None = None
    # None = flag absent (local/dev: no restriction). A set = enforce it.
    allowed_tools: frozenset[str] | None = None
    permission_mode: str | None = None


def _split_allowed_tools(value: str | None) -> frozenset[str] | None:
    """Parse Claude's ``--allowed-tools`` CSV into base tool names.

    Entries may carry a permission scope, e.g. ``Edit(/tmp/*)`` or
    ``Bash(git:*)`` — only the base name gates availability here, so the
    parenthesised scope is stripped. Returns ``None`` when the flag is absent
    so non-gh-aw/local runs keep every tool.
    """
    if value is None:
        return None
    names = set()
    for raw in value.split(","):
        entry = raw.strip()
        if not entry:
            continue
        names.add(entry.split("(", 1)[0].strip())
    return frozenset(names)


def parse_args(argv: Sequence[str]) -> Args:
    """Accept Claude Code's CLI surface; keep what we use, tolerate the rest
    so a future Claude flag never breaks the engine."""
    p = argparse.ArgumentParser(add_help=False)
    p.add_argument("--model")
    p.add_argument("--mcp-config")
    p.add_argument("--prompt-file")
    p.add_argument("--output-format", default="stream-json")
    p.add_argument("--allowed-tools")
    p.add_argument("--permission-mode")
    p.add_argument("--debug-file")
    for flag in ("--print", "--no-chrome", "--verbose", "--continue"):
        p.add_argument(flag, action="store_true")
    known, unknown = p.parse_known_args(list(argv))
    # gh-aw appends the rendered prompt as the trailing positional argument.
    positionals = [a for a in unknown if not a.startswith("-")]
    return Args(
        model=known.model,
        mcp_config=known.mcp_config,
        prompt_file=known.prompt_file,
        prompt_positional=positionals[-1] if positionals else None,
        allowed_tools=_split_allowed_tools(known.allowed_tools),
        permission_mode=known.permission_mode,
    )


def resolve_prompt(args: Args) -> str:
    """Prompt precedence: trailing positional -> --prompt-file -> $GH_AW_PROMPT."""
    if args.prompt_positional:
        return args.prompt_positional
    path = args.prompt_file or os.environ.get("GH_AW_PROMPT")
    if path and os.path.isfile(path):
        return pathlib.Path(path).read_text(encoding="utf-8")
    return ""


def _first_env(*names: str) -> str | None:
    """First non-empty value among the given environment variables."""
    for n in names:
        v = os.environ.get(n)
        if v:
            return v
    return None


def _use_openai_provider(provider: str, openai_base: str | None, anthropic_base: str | None) -> bool:
    """Select the OpenAI-compatible path for an explicit ``openai:`` model
    prefix, or when only OPENAI_BASE_URL is configured (local / non-gh-aw use).
    Under gh-aw, ANTHROPIC_BASE_URL is set, so the Anthropic path is used."""
    if provider == "openai":
        return True
    if provider == "anthropic":
        return False
    return openai_base is not None and anthropic_base is None


def build_model(args: Args) -> tuple[Model, str]:
    """Build the `pydantic-ai` model and a human-readable label.

    The harness behaves like the stock Claude Code CLI: gh-aw sets
    ``ANTHROPIC_BASE_URL`` (its in-cluster transparent proxy) and a placeholder
    auth token; the firewall's api-proxy swaps in the real key and rewrites the
    base path. ``pydantic-ai``'s default ``AnthropicProvider`` requires
    ``ANTHROPIC_API_KEY`` and ignores ``ANTHROPIC_AUTH_TOKEN``, so the Anthropic
    client is constructed explicitly with a bearer token, exactly like the CLI.
    Provider selection is intentionally *not* delegated to
    ``infer_model()``: the proxy is the provider abstraction and the firewall
    only allowlists the proxy host, so the harness must stay a proxy client.
    """
    raw = (
        args.model
        or _first_env("GH_AW_HARNESS_MODEL", "GH_AW_MODEL_AGENT_CLAUDE", "ANTHROPIC_MODEL")
        or "claude-sonnet-4-5"
    )
    provider, _, model_name = raw.partition(":") if ":" in raw else ("", "", raw)
    openai_base = os.environ.get("OPENAI_BASE_URL")
    anthropic_base = os.environ.get("ANTHROPIC_BASE_URL")

    if _use_openai_provider(provider, openai_base, anthropic_base):
        api_key = _first_env(
            "GH_AW_HARNESS_API_KEY",
            "OPENAI_API_KEY",
            "ANTHROPIC_API_KEY",
            "ANTHROPIC_AUTH_TOKEN",
        ) or PROXY_PLACEHOLDER
        base_url = openai_base or anthropic_base
        log(f"openai-compatible base_url={base_url or '(default)'}")
        provider_obj = OpenAIProvider(api_key=api_key, base_url=base_url)
        return OpenAIChatModel(model_name, provider=provider_obj), f"openai-compatible:{model_name}"

    auth_token = _first_env(
        "ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_API_KEY", "GH_AW_HARNESS_API_KEY"
    ) or PROXY_PLACEHOLDER
    log(f"anthropic base_url={anthropic_base or '(default)'} auth=token")
    client = AsyncAnthropic(auth_token=auth_token, base_url=anthropic_base)
    label = raw if ":" in raw else f"anthropic:{model_name}"
    return AnthropicModel(model_name, provider=AnthropicProvider(anthropic_client=client)), label


def configure_observability() -> None:
    """pydantic-ai is natively instrumented; gh-aw injects OTEL_*/LOGFIRE_TOKEN
    so traces flow with no extra config. Never let observability break the run."""
    if not (
        os.environ.get("OTEL_EXPORTER_OTLP_ENDPOINT")
        or os.environ.get("GH_AW_OTLP_ENDPOINTS")
        or os.environ.get("LOGFIRE_TOKEN")
    ):
        return
    try:
        logfire.configure(
            service_name=os.environ.get("OTEL_SERVICE_NAME", "gh-aw"),
            send_to_logfire="if-token-present",
            console=False,
        )
        logfire.instrument_pydantic_ai()
        log("Logfire/OTLP instrumentation enabled")
    except Exception as exc:  # noqa: BLE001 - telemetry must never fail the run
        log(f"observability disabled: {exc!r}")


# --------------------------------------------------------------------------- #
# MCP bridge
# --------------------------------------------------------------------------- #
def _mcp_tool_allowed(server: str, allowed: frozenset[str]) -> Callable[[RunContext[Any], ToolDefinition], bool]:
    """Build a `MCPToolset.filtered` predicate enforcing gh-aw's allow-list.

    gh-aw lists MCP tools as ``mcp__<server>`` (whole server) or
    ``mcp__<server>__<tool>`` (one tool). The harness does not prefix tool
    names, so the model sees a server tool by its canonical name; map it back
    to the gh-aw identifier here.
    """
    server_wildcard = f"mcp__{server}" in allowed

    def predicate(_ctx: RunContext[Any], tool_def: ToolDefinition) -> bool:
        return server_wildcard or f"mcp__{server}__{tool_def.name}" in allowed

    return predicate


def build_mcp_servers(args: Args) -> list[AbstractToolset[Any]]:
    """Translate gh-aw's Claude-format ``mcp-servers.json`` into `pydantic-ai`
    toolsets.

    ``container:``-type servers (e.g. the GitHub server) are launched by
    gh-aw's gateway and reached over its http endpoint, so only stdio/http
    entries are instantiated here. Tools are **not** prefixed: gh-aw's
    safe-output instructions reference canonical names (e.g. ``add_comment``);
    a ``PrefixedToolset`` would rename them and cause intermittent posting.
    When ``--allowed-tools`` is set, each server is wrapped in a filter so the
    model only sees gh-aw-permitted tools.
    """
    path = args.mcp_config or os.environ.get("GH_AW_MCP_CONFIG")
    if not path or not os.path.isfile(path):
        log("no MCP config present — running without external tools")
        return []
    cfg = json.loads(pathlib.Path(path).read_text(encoding="utf-8"))

    servers: list[AbstractToolset[Any]] = []
    for name, spec in (cfg.get("mcpServers") or {}).items():
        toolset: AbstractToolset[Any]
        if spec.get("type") in ("http", "sse") or spec.get("url"):
            toolset = MCPToolset(spec["url"], headers=spec.get("headers") or None)
        elif spec.get("command"):
            from fastmcp.client.transports import StdioTransport

            toolset = MCPToolset(
                StdioTransport(
                    command=spec["command"],
                    args=spec.get("args", []),
                    env={**os.environ, **(spec.get("env") or {})},
                )
            )
        else:
            log(f"skipping MCP server {name!r} (gateway-launched container)")
            continue

        if args.allowed_tools is not None:
            toolset = toolset.filtered(_mcp_tool_allowed(name, args.allowed_tools))
            log(f"registered MCP server {name!r} (allow-list filtered)")
        else:
            log(f"registered MCP server {name!r} (no allow-list)")
        servers.append(toolset)
    return servers


# --------------------------------------------------------------------------- #
# Native tools — Claude Code names & parameter names, workspace-scoped, run
# inside the AWF firewall sandbox. `pydantic-ai` drives the multi-step loop.
# --------------------------------------------------------------------------- #
MAX_TOOL_OUTPUT = 16000
WORKSPACE = os.environ.get("GITHUB_WORKSPACE") or os.getcwd()


def _clip(text: str) -> str:
    if len(text) <= MAX_TOOL_OUTPUT:
        return text
    return text[:MAX_TOOL_OUTPUT] + f"\n…[truncated {len(text) - MAX_TOOL_OUTPUT} chars]"


def _resolve(path: str) -> pathlib.Path:
    p = pathlib.Path(path)
    return p if p.is_absolute() else pathlib.Path(WORKSPACE) / p


def bash(command: str, timeout: int | None = None) -> str:
    """Run a shell command in the repository workspace.

    Returns combined stdout+stderr (truncated). `timeout` is in seconds
    (default 120, capped at 600).
    """
    secs = 120 if not timeout or timeout <= 0 else min(int(timeout), 600)
    try:
        r = subprocess.run(
            command, shell=True, cwd=WORKSPACE, capture_output=True, text=True, timeout=secs
        )
        return _clip(f"exit={r.returncode}\n{r.stdout}{r.stderr}")
    except subprocess.TimeoutExpired:
        return f"error: command timed out after {secs}s"


def read_file(file_path: str, offset: int | None = None, limit: int | None = None) -> str:
    """Read a UTF-8 text file. Relative paths resolve under the workspace.

    Optional 1-based line `offset` and line `limit` mirror Claude's Read tool.
    """
    try:
        text = _resolve(file_path).read_text(encoding="utf-8", errors="replace")
    except OSError as exc:
        return f"error: {exc}"
    if offset is None and limit is None:
        return _clip(text)
    lines = text.splitlines()
    start = max((offset or 1) - 1, 0)
    end = start + limit if limit else len(lines)
    return _clip("\n".join(lines[start:end]))


def write_file(file_path: str, content: str) -> str:
    """Create or overwrite a UTF-8 text file under the workspace."""
    try:
        p = _resolve(file_path)
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content, encoding="utf-8")
        return f"wrote {len(content)} chars to {p}"
    except OSError as exc:
        return f"error: {exc}"


def edit_file(file_path: str, old_string: str, new_string: str, replace_all: bool = False) -> str:
    """Replace `old_string` with `new_string` in a workspace file.

    Replaces the first occurrence, or every occurrence when `replace_all`.
    """
    try:
        p = _resolve(file_path)
        text = p.read_text(encoding="utf-8")
        if old_string not in text:
            return "error: `old_string` not found"
        edited = text.replace(old_string, new_string, -1 if replace_all else 1)
        p.write_text(edited, encoding="utf-8")
        return f"edited {p}"
    except OSError as exc:
        return f"error: {exc}"


def list_dir(path: str = ".") -> str:
    """List a workspace directory's entries (directories marked with `/`)."""
    try:
        p = _resolve(path)
        return _clip(
            "\n".join(sorted(e.name + ("/" if e.is_dir() else "") for e in p.iterdir()))
            or "(empty)"
        )
    except OSError as exc:
        return f"error: {exc}"


def glob_search(pattern: str, path: str = ".") -> str:
    """Return workspace paths matching a glob `pattern` (supports `**`)."""
    base = _resolve(path)
    try:
        matches = sorted(
            str(pathlib.Path(m).relative_to(base))
            for m in globlib.glob(str(base / pattern), recursive=True)
        )
    except OSError as exc:
        return f"error: {exc}"
    return _clip("\n".join(matches) or "(no matches)")


def grep(pattern: str, path: str = ".") -> str:
    """Recursively regex-search workspace files (ripgrep if available, else a
    Python fallback). Returns `file:line:text` matches (capped)."""
    base = _resolve(path)
    rg = shutil.which("rg")
    if rg:
        try:
            r = subprocess.run(
                [rg, "-n", "--no-heading", "-e", pattern, str(base)],
                capture_output=True,
                text=True,
                timeout=60,
            )
            return _clip(r.stdout or "(no matches)")
        except subprocess.TimeoutExpired:
            return "error: grep timed out"
    try:
        rx = re.compile(pattern)
    except re.error as exc:
        return f"error: bad regex: {exc}"
    out: list[str] = []
    for f in base.rglob("*"):
        if not f.is_file():
            continue
        try:
            for i, ln in enumerate(f.read_text(encoding="utf-8", errors="ignore").splitlines(), 1):
                if rx.search(ln):
                    out.append(f"{f}:{i}:{ln}")
                    if len(out) >= 500:
                        return _clip("\n".join(out))
        except OSError:
            continue
    return _clip("\n".join(out) or "(no matches)")


# Claude tool name -> (callable, one-line description). The function names stay
# idiomatic snake_case; `pydantic_ai.Tool` exposes them under the Claude names.
NATIVE_TOOLS: dict[str, tuple[Callable[..., str], str]] = {
    "Bash": (bash, "Run a shell command in the repository workspace."),
    "Read": (read_file, "Read a UTF-8 text file (optional line offset/limit)."),
    "Write": (write_file, "Create or overwrite a workspace text file."),
    "Edit": (edit_file, "Replace a string in a workspace file."),
    "Grep": (grep, "Recursively regex-search workspace files."),
    "Glob": (glob_search, "List workspace paths matching a glob pattern."),
    "LS": (list_dir, "List a workspace directory's entries."),
}


def select_native_tools(
    allowed: frozenset[str] | None, permission_mode: str | None
) -> list[Tool[None]]:
    """Build the native `Tool`s, honoring gh-aw's allow-list and permission
    mode. ``allowed=None`` (flag absent) keeps every tool. ``plan`` mode
    withholds workspace-mutating tools.
    """
    plan = permission_mode == "plan"
    tools: list[Tool[None]] = []
    for name in NATIVE_TOOL_NAMES:
        if allowed is not None and name not in allowed:
            continue
        if plan and name in MUTATING_TOOLS:
            continue
        fn, desc = NATIVE_TOOLS[name]
        tools.append(Tool(fn, name=name, description=desc))
    return tools


# --------------------------------------------------------------------------- #
# Claude-compatible stream-json output
# --------------------------------------------------------------------------- #
def emit(obj: dict[str, Any]) -> None:
    """Write one Claude-style stream-json line to stdout."""
    sys.stdout.write(json.dumps(obj) + "\n")
    sys.stdout.flush()


def emit_result(
    text: str,
    usage: Any,
    session_id: str,
    is_error: bool = False,
    num_turns: int = 1,
    duration_ms: int = 0,
) -> None:
    def tok(*names: str) -> int:
        for n in names:
            v = getattr(usage, n, None)
            if isinstance(v, int):
                return v
        return 0

    emit(
        {
            "type": "result",
            "subtype": "error" if is_error else "success",
            "is_error": is_error,
            "result": text,
            "session_id": session_id,
            "num_turns": num_turns,
            "duration_ms": duration_ms,
            "total_cost_usd": 0,
            "usage": {
                "input_tokens": tok("input_tokens", "request_tokens"),
                "output_tokens": tok("output_tokens", "response_tokens"),
                "cache_creation_input_tokens": tok("cache_write_tokens", "cache_creation_input_tokens"),
                "cache_read_input_tokens": tok("cache_read_tokens", "cache_read_input_tokens"),
            },
        }
    )


async def log_mcp_tools(mcp_servers: Iterable[AbstractToolset[Any]]) -> None:
    """Log the tool names each connected MCP server exposes (post-filter), so a
    missing or renamed safe-outputs tool is immediately visible."""
    for server in mcp_servers:
        label = getattr(server, "label", None) or getattr(server, "id", "?")
        try:
            tools = await server.list_tools()  # type: ignore[attr-defined]
            names: Any = [getattr(t, "name", str(t)) for t in tools]
        except Exception as exc:  # noqa: BLE001 - discovery is diagnostic only
            names = f"<list_tools failed: {exc!r}>"
        log(f"MCP server {label!r} tools={names}")


def emit_tool_activity(messages: Sequence[Any]) -> int:
    """Emit Claude-style tool_use / tool_result blocks from the run's message
    history so tool calls are visible to gh-aw's parser. Returns the count."""
    tool_calls = 0
    for message in messages:
        for part in getattr(message, "parts", []):
            if isinstance(part, ToolCallPart):
                tool_calls += 1
                emit(
                    {
                        "type": "assistant",
                        "message": {
                            "role": "assistant",
                            "content": [
                                {
                                    "type": "tool_use",
                                    "id": part.tool_call_id or "",
                                    "name": part.tool_name or "",
                                    "input": part.args_as_dict(),
                                }
                            ],
                        },
                    }
                )
                log(f"tool_use: {part.tool_name}")
            elif isinstance(part, ToolReturnPart):
                emit(
                    {
                        "type": "user",
                        "message": {
                            "role": "user",
                            "content": [
                                {
                                    "type": "tool_result",
                                    "tool_use_id": part.tool_call_id or "",
                                    "content": str(part.content),
                                }
                            ],
                        },
                    }
                )
    return tool_calls


def log_safe_outputs_state() -> None:
    """Whether anything reached the gh-aw safe-outputs sink — this file gates
    the downstream safe_outputs job."""
    path = os.environ.get("GH_AW_SAFE_OUTPUTS")
    if not path:
        log("GH_AW_SAFE_OUTPUTS not set")
        return
    try:
        data = pathlib.Path(path).read_text(encoding="utf-8")
    except OSError as exc:
        log(f"GH_AW_SAFE_OUTPUTS unreadable ({path}): {exc!r}")
        return
    lines = [ln for ln in data.splitlines() if ln.strip()]
    log(f"GH_AW_SAFE_OUTPUTS={path} entries={len(lines)} bytes={len(data)}")
    for ln in lines[:5]:
        log(f"  safe-output: {ln[:300]}")


async def run(
    prompt: str,
    model: Model,
    label: str,
    native_tools: list[Tool[None]],
    mcp_servers: list[AbstractToolset[Any]],
    session_id: str,
) -> int:
    agent = Agent(model, tools=native_tools, toolsets=mcp_servers or None)
    emit({"type": "system", "subtype": "init", "session_id": session_id, "model": label})

    started = time.perf_counter()
    try:
        if mcp_servers:
            async with agent:
                await log_mcp_tools(mcp_servers)
                result = await agent.run(prompt)
        else:
            result = await agent.run(prompt)
    except Exception as exc:  # noqa: BLE001 - surface as a Claude-style error result
        log(f"agent run failed: {exc!r}")
        emit_result(
            f"agent run failed: {exc}",
            usage=None,
            session_id=session_id,
            is_error=True,
            duration_ms=round((time.perf_counter() - started) * 1000),
        )
        return 1

    duration_ms = round((time.perf_counter() - started) * 1000)
    messages = result.all_messages()
    tool_calls = emit_tool_activity(messages)
    num_turns = sum(isinstance(m, ModelResponse) for m in messages)
    log(f"tool calls observed: {tool_calls}, turns: {num_turns}")

    text = str(result.output or "")
    emit({"type": "assistant", "message": {"role": "assistant", "content": text}})

    usage = result.usage
    if callable(usage):  # pydantic-ai <1.x exposed usage() as a method
        usage = usage()
    emit_result(text, usage, session_id, num_turns=num_turns, duration_ms=duration_ms)
    log_safe_outputs_state()
    return 0


def main() -> int:
    """Entry point. Any failure is surfaced as a Claude-style stream-json error
    result so gh-aw always has a structured outcome to parse (never an opaque
    'no structured log entries' run)."""
    session_id = (os.environ.get("GITHUB_RUN_ID") or "local") + "-" + uuid.uuid4().hex[:8]
    try:
        args = parse_args(sys.argv[1:])
        configure_observability()
        prompt = resolve_prompt(args)
        if not prompt.strip():
            log("empty prompt — nothing to do")
            emit_result("empty prompt", usage=None, session_id=session_id, is_error=True)
            return 1
        model, label = build_model(args)
        native_tools = select_native_tools(args.allowed_tools, args.permission_mode)
        mcp_servers = build_mcp_servers(args)
        log(
            f"model={label} permission_mode={args.permission_mode or '(none)'} "
            f"native_tools={[t.name for t in native_tools]} "
            f"mcp_servers={len(mcp_servers)} prompt_chars={len(prompt)}"
        )
        started = time.time()
        rc = asyncio.run(run(prompt, model, label, native_tools, mcp_servers, session_id))
        log(f"done in {time.time() - started:.1f}s rc={rc}")
        return rc
    except Exception as exc:  # noqa: BLE001 - startup failures must still be structured
        log(f"FATAL startup error: {exc!r}")
        emit_result(f"harness startup failed: {exc}", usage=None, session_id=session_id, is_error=True)
        return 1


if __name__ == "__main__":
    sys.exit(main())
